VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# VITE_GEMINI_API_KEY is no longer required — Gemini now runs through the
# /api/gemini serverless proxy (key stays server-side, see GEMINI_API_KEY below).
# Leave it set ONLY during migration: it's a temporary client fallback that
# keeps AI working until GEMINI_API_KEY is configured. Remove it from the
# deployment once the proxy is confirmed working, to fully protect the key.
# VITE_GEMINI_API_KEY=your-gemini-key-from-aistudio

# ── Server-side only (set in Vercel → Project → Settings → Environment Variables)
# Never expose these with a VITE_ prefix — they must not reach the browser.
GEMINI_API_KEY=your-gemini-key-from-aistudio
RAZORPAY_WEBHOOK_SECRET=set-this-when-creating-the-webhook-in-razorpay
SUPABASE_SERVICE_ROLE_KEY=from-supabase-settings-api-service-role
SUPABASE_URL=https://your-project-id.supabase.co
